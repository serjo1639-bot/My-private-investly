###############################################################################
# ADMIN — WALLET MANAGEMENT
###############################################################################

### List All Wallets
GET {{baseUrl}}/admin/wallets
Authorization: Bearer {{token}}

---

### List Wallets with search
GET {{baseUrl}}/admin/wallets?search=ahmed
Authorization: Bearer {{token}}

---

### Transfer Between Wallets
POST {{baseUrl}}/admin/wallet/transfer
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fromUserId": "SOURCE_USER_ID_HERE",
  "toUserId": "TARGET_USER_ID_HERE",
  "amount": 500,
  "reason": "Manual correction transfer"
}

---

###############################################################################
# ADMIN — NOTIFICATIONS
###############################################################################

### Send Notification to One User
POST {{baseUrl}}/admin/notifications/send
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "{{userId}}",
  "titleAr": "إشعار مخصص",
  "titleEn": "Custom Notification",
  "messageAr": "رسالة مخصصة لك",
  "messageEn": "This message is just for you",
  "type": "system"
}

---

### Broadcast Notification to ALL Users
POST {{baseUrl}}/admin/notifications/send
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": null,
  "titleAr": "إعلان للجميع",
  "titleEn": "Announcement for Everyone",
  "messageAr": "مرحباً بجميع المستخدمين",
  "messageEn": "Welcome to all users",
  "type": "system"
}
